# Ignore everything by default
*

# Allow directories so Git can traverse the tree
!*/

# Ignore Rust build output
target/

# Keep Git metadata and config
!.gitignore
!.github/
!.github/**

# Rust sources and Cargo manifests
!*.rs
!Cargo.toml
!Cargo.lock

# Documentation and examples
!*.md
!Dockerfile
!LICENSE
!*.example.json
