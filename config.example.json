{
  "server": {
    "port": "53",
    "pprof": "6060",
    "log_level": "info",
    "tls": {
      "port": "853",
      "cert_file": "/path/to/cert.pem",
      "key_file": "/path/to/key.pem",
      "self_signed": false,
      "https": {
        "port": "443",
        "endpoint": "/dns-query"
      }
    },
    "features": {
      "ddr": {
        "domain": "dns.example.com",
        "ipv4": "127.0.0.1",
        "ipv6": "::1"
      },
      "ecs_subnet": {
        "ipv4": "auto",
        "ipv6": "auto",
        "prefer_ipv4": true
      },
      "hijack_protection": true,
      "cache": {
        "memory": {
          "size": 10000
        },
        "redis": {
          "address": "127.0.0.1:6379",
          "password": "",
          "database": 0,
          "key_prefix": "zjdns:"
        }
      },
      "latency_probe": [
        {
          "protocol": "ping",
          "timeout": 100
        },
        {
          "protocol": "tcp",
          "port": 443,
          "timeout": 100
        },
        {
          "protocol": "tcp",
          "port": 80,
          "timeout": 100
        },
        {
          "protocol": "udp",
          "port": 53,
          "timeout": 100
        },
        {
          "protocol": "http",
          "port": 80,
          "timeout": 100
        },
        {
          "protocol": "https",
          "port": 443,
          "timeout": 100
        },
        {
          "protocol": "http3",
          "port": 443,
          "timeout": 100
        }
      ],
      "stats": {
        "interval": 0,
        "reset_interval": 0
      }
    }
  },
  "upstream": [
    {
      "address": "223.5.5.5:53",
      "protocol": "tcp",
      "server_name": "",
      "skip_tls_verify": false
    },
    {
      "address": "223.6.6.6:53",
      "protocol": "udp",
      "server_name": "",
      "skip_tls_verify": false
    },
    {
      "address": "223.5.5.5:853",
      "protocol": "tls",
      "server_name": "dns.alidns.com",
      "skip_tls_verify": false
    },
    {
      "address": "223.6.6.6:853",
      "protocol": "quic",
      "server_name": "dns.alidns.com",
      "skip_tls_verify": true
    },
    {
      "address": "https://223.5.5.5:443/dns-query",
      "protocol": "https",
      "server_name": "dns.alidns.com",
      "skip_tls_verify": false,
      "match": ["mixed"]
    },
    {
      "address": "https://223.6.6.6:443/dns-query",
      "protocol": "http3",
      "server_name": "dns.alidns.com",
      "skip_tls_verify": false,
      "match": ["!mixed"]
    },
    {
      "address": "builtin_recursive",
      "protocol": "",
      "server_name": "",
      "skip_tls_verify": false
    }
  ],
  "fallback": [
    {
      "address": "builtin_recursive",
      "protocol": "",
      "server_name": "",
      "skip_tls_verify": false
    }
  ],
  "rewrite": [
    { "exclude_clients": ["10.0.0.100"] },
    {
      "name": "client-specific.example.com",
      "include_clients": ["192.168.0.0/24"],
      "records": [
        {
          "type": "A",
          "class": "IN",
          "ttl": 10,
          "content": "127.0.0.1"
        }
      ]
    },
    {
      "name": "blocked.example.com",
      "exclude_clients": ["192.168.1.0/24"],
      "records": [
        {
          "type": "A",
          "class": "IN",
          "ttl": 10,
          "content": "127.0.0.1"
        }
      ]
    },
    {
      "name": "ipv6.blocked.example.com",
      "records": [
        {
          "type": "AAAA",
          "ttl": 10,
          "content": "::1"
        }
      ]
    }
  ],
  "cidr": [
    {
      "file": "whitelist.txt",
      "tag": "file"
    },
    {
      "rules": ["192.168.0.0/16", "10.0.0.0/8", "2001:db8::/32"],
      "tag": "rules"
    },
    {
      "file": "blacklist.txt",
      "rules": ["127.0.0.1/32"],
      "tag": "mixed"
    }
  ]
}
